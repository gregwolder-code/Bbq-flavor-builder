# Turso Database (SQLite for production)
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-auth-token"

# For local development (no Turso needed):
# Just leave TURSO_DATABASE_URL unset - it will auto-fallback to local SQLite

# NextAuth - Required for authentication
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-change-me"
AUTH_URL="http://localhost:3000"

# OAuth Providers (optional - leave empty to use email/password only)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""
